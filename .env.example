# --- Runtime
NODE_ENV=development
LOG_LEVEL=info

# --- Database
DATABASE_URL=postgresql://liturgia:liturgia_dev@localhost:5433/liturgia_pro

# --- Schedule (cron expression + timezone)
DISPATCH_CRON=0 5 * * *
DISPATCH_TZ=America/Sao_Paulo

# --- Groq (reflection)
# Obter chave gratis em https://console.groq.com (sem cartao de credito)
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# --- Azure Speech (TTS)
# Get keys at https://portal.azure.com (Speech Services resource)
AZURE_SPEECH_KEY=your-key-here
AZURE_SPEECH_REGION=brazilsouth

# --- WhatsApp (Baileys)
# Group ID format: 120363xxxxxxxxx@g.us  (descobrir apos pareamento)
# Admin number for failure alerts: 55DDDNUMBER@s.whatsapp.net
WHATSAPP_GROUP_ID=
WHATSAPP_ADMIN_NUMBER=
# Numero do chip do bot (so digitos com DDI). Usado no pareamento Baileys.
# Ex: 5511999999999
WHATSAPP_BOT_NUMBER=
# Numero pessoal pra smoke test (recebe a mensagem teste do bot).
WHATSAPP_TEST_NUMBER=

# --- Storage
AUDIO_STORAGE_PATH=./storage/audios
